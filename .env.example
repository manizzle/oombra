# nur configuration
# Copy to .env and customize

# ── Server ──────────────────────────────────────────────────
NUR_PORT=8000
NUR_API_KEY=
NUR_MIN_K=3

# ── Database ────────────────────────────────────────────────
NUR_DB_URL=sqlite+aiosqlite:///data/nur.db
# PostgreSQL (production):
# NUR_DB_URL=postgresql+asyncpg://nur:changeme@postgres:5432/nur
# POSTGRES_PASSWORD=changeme

# ── Feed Ingestion ──────────────────────────────────────────
NUR_AUTO_INGEST=0

# ── Domain (HTTPS via Caddy) ────────────────────────────────
# NUR_DOMAIN=nur.yourdomain.com

# ── API Keys (optional — more keys = more data) ─────────────
ABUSEIPDB_API_KEY=
PULSEDIVE_API_KEY=
OTX_API_KEY=
GREYNOISE_API_KEY=
HYBRID_ANALYSIS_API_KEY=
GITHUB_TOKEN=
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
