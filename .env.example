# nur configuration
# Copy to .env and customize
#
# SECRETS: Never commit real values. Use AWS Secrets Manager in production:
#   NUR_SECRETS_ARN=arn:aws:secretsmanager:us-west-2:ACCOUNT:secret:nur/prod
#   All values below are overridden by secrets from AWS when the ARN is set.

# ── Server ──────────────────────────────────────────────────
NUR_PORT=8000
NUR_API_KEY=
NUR_MIN_K=3

# ── Database ────────────────────────────────────────────────
NUR_DB_URL=sqlite+aiosqlite:///data/nur.db
# POSTGRES_PASSWORD=

# ── Feed Ingestion ──────────────────────────────────────────
NUR_AUTO_INGEST=0

# ── Domain ──────────────────────────────────────────────────
# NUR_DOMAIN=

# ── Secrets Manager (production) ────────────────────────────
# Set this to load all secrets from AWS Secrets Manager instead of .env
# NUR_SECRETS_ARN=

# ── Feed API Keys ───────────────────────────────────────────
# ABUSEIPDB_API_KEY=
# PULSEDIVE_API_KEY=
# OTX_API_KEY=
# GREYNOISE_API_KEY=
# HYBRID_ANALYSIS_API_KEY=
# GITHUB_TOKEN=

# ── Email (SMTP) ───────────────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
