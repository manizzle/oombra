# vigil configuration
# Copy this to .env and customize for your deployment

# ── Server ──────────────────────────────────────────────────
# Port to expose (default: 8000)
VIGIL_PORT=8000

# API key for write endpoints (leave blank for open access)
# Anyone submitting data needs this key
VIGIL_API_KEY=

# Minimum contributors before showing aggregates (default: 3)
# Privacy protection: prevents de-anonymization of small groups
VIGIL_MIN_K=3

# ── Database ────────────────────────────────────────────────
# SQLite (default — zero config, good for single-server)
VIGIL_DB_URL=sqlite+aiosqlite:///data/vigil.db

# PostgreSQL (for production — use with `docker compose --profile production up`)
# VIGIL_DB_URL=postgresql+asyncpg://vigil:changeme@postgres:5432/vigil
# POSTGRES_PASSWORD=changeme

# ── Live Feed Ingestion ─────────────────────────────────────
# Set to 1 to auto-scrape public threat feeds every hour
# Feeds: ThreatFox, Feodo Tracker, MalwareBazaar, CISA KEV
VIGIL_AUTO_INGEST=0
